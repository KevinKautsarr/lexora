# Salin ke .env dan isi nilainya. JANGAN commit .env.

# Connection string Postgres (Neon): Dashboard Neon → Connection Details
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Secret Better Auth — generate dengan: openssl rand -hex 32
BETTER_AUTH_SECRET="ganti-dengan-string-acak-64-karakter"

# URL aplikasi. Dev: http://localhost:3000
# Production (Vercel): https://nama-app.vercel.app (atau custom domain)
BETTER_AUTH_URL="http://localhost:3000"

# Login Google (opsional — tombol Google tidak berfungsi tanpa ini).
# Buat di https://console.cloud.google.com → APIs & Services → Credentials
# → Create Credentials → OAuth client ID → Web application.
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
#   Dev:  http://localhost:3000/api/auth/callback/google
#   Prod: https://nama-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Pengirim email (reset password) — https://resend.com → API Keys.
# Tanpa key ini, halaman lupa-password akan menampilkan error saat mengirim.
# EMAIL_FROM untuk testing boleh dikosongkan (default onboarding@resend.dev,
# hanya bisa mengirim ke email pemilik akun Resend). Produksi: verifikasi
# domain di Resend lalu isi "Lexora <noreply@domainmu.com>".
RESEND_API_KEY=""
EMAIL_FROM=""
