# Salin ke .env dan isi nilainya. JANGAN commit .env.

# Connection string Postgres (Neon): Dashboard Neon → Connection Details
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Secret Better Auth — generate dengan: openssl rand -hex 32
BETTER_AUTH_SECRET="ganti-dengan-string-acak-64-karakter"

# URL aplikasi. Dev: http://localhost:3000
# Production (Vercel): https://nama-app.vercel.app (atau custom domain)
BETTER_AUTH_URL="http://localhost:3000"
